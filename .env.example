# ── Alpaca (paper trading + live price data) ─────────────────────────────────
# Free account at alpaca.markets — use paper credentials
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here
ALPACA_ENV=paper                    # paper or live

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_system
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── Anthropic (Layer 2 AI scoring) ───────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here

# ── Finnhub (news headlines for Layer 2) ─────────────────────────────────────
FINNHUB_API_KEY=your_key_here

# ── Tradier (SIP volume data — scanning + 5-min bars) ────────────────────────
# Free sandbox at developer.tradier.com; live requires brokerage account
TRADIER_TOKEN=your_token_here
TRADIER_ENV=sandbox                 # sandbox or live

# ── Twilio (SMS confirmation + EOD report) ───────────────────────────────────
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM=+18339595082            # your Twilio number (E.164)
TWILIO_TO=+15551234567              # your phone number (E.164)

# ── Risk parameters ───────────────────────────────────────────────────────────
TRADING_CAPITAL=8000                # current account balance in dollars
RISK_PCT_PER_TRADE=1.0              # % of capital to risk per trade (1% = $80 on $8k)
MAX_POSITION_PCT=95.0               # max single-position % of capital
                                    # set high for intraday — RISK_PCT controls actual exposure

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PORT=5000

# ── Account progress page ─────────────────────────────────────────────────────
ACCOUNT_START_BALANCE=8000          # starting balance for compound curve chart
ACCOUNT_MONTHLY_TARGET_PCT=8        # monthly growth target % (20 trading days)

# ── Email reports (optional — skipped if unset) ───────────────────────────────
EMAIL_FROM=you@gmail.com
EMAIL_TO=you@gmail.com              # comma-separated for multiple recipients
EMAIL_PASSWORD=your_app_password    # Gmail: 16-char app password (no spaces)
EMAIL_SMTP_HOST=smtp.gmail.com      # defaults to smtp.gmail.com if unset
EMAIL_SMTP_PORT=587                 # defaults to 587 if unset

# ── Google Sheets (optional — skipped if unset) ───────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service_account.json
SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
